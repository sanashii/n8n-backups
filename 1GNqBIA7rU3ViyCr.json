      {
        "parameters": {
          "jsCode": "const body       = $('When Called By Another Workflow').first().json.body;\nconst allRecords = $input.all();\n\n// Grab the attachment from the slash command option\nconst attachmentOption = body.data.options?.find(o => o.name === 'photo');\nif (!attachmentOption) throw new Error('No photo option found in command.');\n\nconst attachment = body.data.resolved?.attachments?.[attachmentOption.value];\nif (!attachment) throw new Error('Could not resolve attachment from Discord.');\n\nif (allRecords.length === 0) {\n  throw new Error('No disbursement records found without a receipt. All caught up!');\n}\n\n// Most recent record without receipt (sorted desc already)\nconst target = allRecords[0];\nconst fields  = target.json.fields || {};\n\nreturn [{\n  json: {\n    recordId:       target.json.id,\n    fileUrl:        attachment.url,\n    filename:       attachment.filename,\n    dateReceived:   fields['Date Received']  || 'N/A',\n    particulars:    fields['Particulars']    || 'N/A',\n    amountReceived: fields['Amount Received'] || 0\n  }\n}];"
        },
