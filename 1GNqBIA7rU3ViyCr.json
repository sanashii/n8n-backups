          "body": "={{ (() => {\n  const d = $('Code: Process Upload Receipt').first().json;\n  return JSON.stringify({\n    embeds: [{\n      title: \"Receipt filed. Finally.\",\n      description: \"Okay okay, I attached it! Stop worrying so much. It's saved in the records now so don't you dare lose the original copy either!\",\n      color: 16007990,\n      fields: [\n        { name: \"Particulars\",   value: d.particulars,                                                                inline: true  },\n        { name: \"Amount\",        value: `\\u20b1${Number(d.amountReceived).toLocaleString('en-PH')}`,                 inline: true  },\n        { name: \"File Attached\", value: `[${d.filename}](${d.fileUrl})`,                                            inline: false }\n      ],\n      footer: { text: \"Momo Bot \\u2022 Don't lose the physical copy either, got it?!\" }\n    }]\n  });\n})() }}",
