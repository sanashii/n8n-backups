    {
      "parameters": {
        "jsCode": "// 1. Extract the raw text from the input\nlet rawText = $input.first().json.text;\n\n// 2. Clean up: Remove Markdown code blocks if the LLM included them\nrawText = rawText.replace(/```json|```/g, \"\").trim();\n\ntry {\n  const parsed = JSON.parse(rawText);\n\n  // 3. Map the data to individual Key-Value pairs for your columns\n  return {\n    // Info for the Sheet\n    Short_Title: parsed.ViralShortScript?.title || \"No Title\",\n    Short_Script: parsed.ViralShortScript?.script || \"No Script\",\n    \n    // Critique Points (Now processing simple strings from the new format)\n    Gap_1_Detail: parsed.Critique?.[0] || \"N/A\",\n    Gap_2_Detail: parsed.Critique?.[1] || \"N/A\",\n    Gap_3_Detail: parsed.Critique?.[2] || \"N/A\",\n    \n    // Long Form Outline\n    Long_Title: parsed.DefinitiveLongScriptOutline?.title || \"No Long Title\",\n    Outline_Full: parsed.DefinitiveLongScriptOutline?.outline \n      ? parsed.DefinitiveLongScriptOutline.outline.map(o => `${o.section}: ${o.content}`).join('\\n\\n') \n      : \"No Outline Available\",\n    \n    // Final CTA (The new format uses a simple string instead of an object)\n    CTA_Message: typeof parsed.CallToAction === 'string' \n      ? parsed.CallToAction \n      : (parsed.CallToAction?.message || \"No CTA\")\n  };\n} catch (e) {\n  return { \n    error: \"Failed to parse JSON\", \n    message: e.message,\n    raw_text_received: rawText.substring(0, 100) + \"...\" \n  };\n}"
      },
