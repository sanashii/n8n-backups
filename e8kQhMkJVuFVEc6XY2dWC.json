    {
      "parameters": {
        "jsCode": "const allVideos = $input.first().json.videos || [];\nconst actionFigure = allVideos[0]?.action_figure_name || 'the action figure';\nconst runDate = $('Set Variables').first().json.run_date;\n\nlet competitorSection = '';\nconst videoUrls = [];\n\nallVideos.forEach((v, i) => {\n  videoUrls.push(v.video_url);\n  const transcriptSnippet = (v.transcript || '').substring(0, 1800);\n  const viewsFormatted = parseInt(v.view_count || 0).toLocaleString();\n\n  competitorSection += `\\n### COMPETITOR ${i + 1}: \"${v.title}\"\\n`;\n  competitorSection += `Channel: ${v.channel} | Views: ${viewsFormatted} | Likes: ${parseInt(v.like_count || 0).toLocaleString()}\\n`;\n  competitorSection += `URL: ${v.video_url}\\n`;\n  competitorSection += `Transcript Excerpt:\\n${transcriptSnippet || '[No transcript available — use title/description as context]'}\\n`;\n  competitorSection += `---\\n`;\n});\n\nconst prompt = `You are an expert viral TikTok content creator specializing in action figures and collectibles. Your videos consistently hit 500k+ views.\\n\\nI want to create a viral TikTok video about the **${actionFigure}**.\\n\\nHere are transcripts from TOP COMPETITOR videos on YouTube for this product:\\n${competitorSection}\\nAnalyze what works in these competitor videos and create a SUPERIOR TikTok script that:\\n- Opens with a scroll-stopping HOOK in the first 2-3 seconds\\n- Uses high-energy, conversational TikTok language (not stiff or formal)\\n- Highlights the most exciting features (articulation, accessories, sculpt quality, value)\\n- Creates FOMO with authentic hype language\\n- Ends with a CTA that drives saves, follows, and comments\\n- Is 45-60 seconds at TikTok pace (roughly 90-130 words)\\n\\nRespond in EXACTLY this format:\\n\\nHOOK: [Your 2-3 second scroll-stopper]\\n\\nFULL SCRIPT:\\n[Complete script — no stage directions, just the words to say]\\n\\nCTA: [Your closing call to action]\\n\\nWHY THIS BEATS COMPETITORS:\\n- [Specific advantage 1]\\n- [Specific advantage 2]\\n- [Specific advantage 3]`;\n\nreturn [{\n  json: {\n    prompt,\n    action_figure_name: actionFigure,\n    videos_analyzed: allVideos.length,\n    video_urls: videoUrls.join('\\n'),\n    run_date: runDate\n  }\n}];"
      },
      "id": "01ade746-52d1-42f9-a3ad-bc6758da26b9",
      "name": "Build AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        -208
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $vars.OPENAI_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ model: 'gpt-4o', messages: [{ role: 'user', content: $json.prompt }], temperature: 0.8, max_tokens: 1200 }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "f46fbc86-4676-42a0-b375-53b34d663f75",
      "name": "Generate TikTok Script",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1424,
        -208
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst content = response.choices?.[0]?.message?.content || '';\nconst prev = $('Build AI Prompt').first().json;\n\nconst hookMatch = content.match(/HOOK:\\s*([\\s\\S]+?)(?=\\n\\nFULL SCRIPT:|$)/);\nconst scriptMatch = content.match(/FULL SCRIPT:\\s*([\\s\\S]+?)(?=\\n\\nCTA:|$)/);\nconst ctaMatch = content.match(/CTA:\\s*([\\s\\S]+?)(?=\\n\\nWHY THIS|$)/);\nconst whyMatch = content.match(/WHY THIS BEATS COMPETITORS:\\s*([\\s\\S]+?)$/);\n\nconst hook = hookMatch ? hookMatch[1].trim() : '';\nconst script = scriptMatch ? scriptMatch[1].trim() : content;\nconst cta = ctaMatch ? ctaMatch[1].trim() : '';\nconst why = whyMatch ? whyMatch[1].trim() : '';\n\nreturn [{\n  json: {\n    run_date: prev.run_date,\n    action_figure: prev.action_figure_name,\n    hook,\n    full_script: script,\n    cta,\n    why_better_than_competitors: why,\n    videos_analyzed: prev.videos_analyzed,\n    source_video_urls: prev.video_urls,\n    full_ai_response: content\n  }\n}];"
      },
