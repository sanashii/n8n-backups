    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst actionFigureName = $('Set Variables').first().json.action_figure_name;\nconst items = data.items || [];\n\nif (items.length === 0) {\n  throw new Error('No YouTube videos found for: ' + actionFigureName);\n}\n\nreturn items\n  .filter(item => item.id && item.id.videoId)\n  .map(item => ({\n    json: {\n      video_id: item.id.videoId,\n      title: item.snippet.title,\n      channel: item.snippet.channelTitle,\n      channel_id: item.snippet.channelId,\n      description: (item.snippet.description || '').substring(0, 300),\n      published_at: item.snippet.publishedAt,\n      video_url: `https://www.youtube.com/watch?v=${item.id.videoId}`,\n      action_figure_name: actionFigureName\n    }\n  }));"
      },
