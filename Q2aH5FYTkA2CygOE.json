      {
        "parameters": {
          "jsCode": "// HTTP Request returns { records: [{id, fields}, ...] }                      \n  const response = $input.first().json;                     \n  const records  = response.records || [];                                      \n  \n  if (records.length === 0) {                                                   \n    return [{                                               \n      json: {                                                                  \n        content: \"Hah! All caught up! Every disbursement's been paid. Don't go falling behind again, got it?!\",                \n        flags: 64\n      }                                                                         \n    }];                                                     \n  }                                                                            \n\n  const options = records.map(r => {\n    const fields      = r.fields || {};\n    const dateStr     = fields['Date Received']                                 \n      ? new Date(fields['Date Received']).toLocaleDateString('en-PH', {\n  year:'numeric', month:'short', day:'numeric' })                               \n      : 'No date';                                          \n    const amount      = fields['Amount Received']                               \n      ? `₱${Number(fields['Amount Received']).toLocaleString('en-PH')}`\n      : 'No amount';                                                            \n    const particulars = (fields['Particulars'] || 'No particulars').substring(0,\n   40);                                                                         \n    const label       = `${dateStr} — ${amount} (${particulars})`.substring(0,\n  100);                                                                         \n                                                            \n    return { label, value: r.id };  // r.id not r.json.id                       \n  });                                                       \n                                                                               \n  return [{\n    json: {\n      content: \"Ugh, fine! Which one are you paying for? Pick one already, I don't have all day.\",\n      flags: 64,\n      components: [{                                                            \n        type: 1,                                            \n        components: [{                                                         \n          type: 3,\n          custom_id: \"select_record_to_update\",                                 \n          placeholder: \"Choose a disbursement...\",\n          options: options.slice(0, 25)                                         \n        }]\n      }]                                                                       \n    }                                                                           \n  }];"
        },
