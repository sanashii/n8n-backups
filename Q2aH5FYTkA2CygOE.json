        "parameters": {
          "jsCode": "const body = $('When Called By Another Workflow').first().json.body;\n\n// custom_id format: 'update_payment_modal:recXXXXXX'\nconst recordId = body.data.custom_id.split(':')[1];\n\nconst components   = body.data.components;\nconst getValue     = (id) => {\n  const row = components.find(c => c.components[0].custom_id === id);\n  return row ? row.components[0].value.trim() : '';\n};\n\nconst amountPaid = parseFloat(getValue('amount_paid').replace(/[,\\s]/g, '')) || 0;\nconst datePaidRaw = getValue('date_paid');\n\nfunction toISO(str) {\n    const d = new Date(str);\n    return isNaN(d.getTime()) ? null : d.toISOString(); \n  }\n\nreturn [{ json: { recordId, amountPaid, datePaid: toISO(datePaidRaw) } }];"
        },
