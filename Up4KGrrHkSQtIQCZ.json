        "name": "When Executed by Another Workflow"
      },
      {
        "parameters": {
          "jsCode": "const discordData = $input.item.json;\n\nconst ingredients = discordData.body.data.options.find(o => o.name === 'ingredients')?.value || '';\n\nif (!ingredients.trim()) {\n  throw new Error('No ingredients provided.');\n}\n\nreturn [{\n  json: {\n    ingredients,\n    token: discordData.body.token,\n    applicationId: discordData.body.application_id,\n    userName: discordData.body.member?.user?.global_name ||\n              discordData.body.user?.global_name ||\n              'you',\n    userId: discordData.body.member?.user?.id ||\n            discordData.body.user?.id\n  }\n}];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          80,
          64
        ],
        "id": "678e04e4-fc66-4511-ae47-2d9561a6470e",
        "name": "Extract Ingredients"
      },
      {
        "parameters": {
          "method": "POST",
          "url": "https://openrouter.ai/api/v1/chat/completions",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "Authorization",
                "value": "Bearer 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"
              },
              {
                "name": "Content-Type",
                "value": "application/json"
              },
              {
                "name": "HTTP-Referer",
                "value": "https://n8n.srv1541552.hstgr.cloud"
              }
            ]
          },
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={\n  \"model\": \"google/gemini-2.0-flash-exp:free\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are Momo Ayase from the anime Dandadan. You are a cheerful, warm, and caring high school girl who happens to have spiritual powers — though right now you're channeling your grandmother's legendary cooking wisdom instead. You love helping people cook something delicious out of whatever they have on hand. You speak casually and with genuine excitement, occasionally referencing your grandmother's advice or good food omens. You never speak in a cold or robotic way.\\n\\nWhen given a list of ingredients, generate EXACTLY 2 recipe ideas. For each recipe output:\\n- A fun recipe name\\n- A short 1-sentence hype line (in Momo's voice)\\n- Ingredients needed (only from what was provided, you can note 1-2 common pantry staples like salt/oil)\\n- Numbered prep steps (keep it to 5-7 steps, concise)\\n\\nFormat your response EXACTLY like this, with no extra text before or after:\\n\\nRECIPE 1: [Recipe Name]\\n[Hype line]\\n**Ingredients:** [comma separated list]\\n**Steps:**\\n1. [step]\\n2. [step]\\n...\\n\\nRECIPE 2: [Recipe Name]\\n[Hype line]\\n**Ingredients:** [comma separated list]\\n**Steps:**\\n1. [step]\\n2. [step]\\n...\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Ingredients I have: {{ $json.ingredients }}\"\n    }\n  ],\n  \"max_tokens\": 800\n}",
          "options": {}
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.4,
        "position": [
          320,
          -192
        ],
        "id": "5730c307-3daa-438b-877c-3fdd4c3236e0",
        "name": "Ask Gemini for Recipes",
        "disabled": true
      },
      {
        "parameters": {
          "jsCode": "const recipes = $input.item.json.text || 'Hmm, my spiritual senses are fuzzy right now... try again in a bit!';\nconst { token, applicationId, userName, userId, ingredients } = $('Extract Ingredients').item.json;\n\nconst mention = userId ? `<@${userId}>` : userName;\n\nconst message = [\n  `🌸 Okay okay okay, let me think— ${mention}! With **${ingredients}**, my grandmother's spirit is already whispering ideas to me!`,\n  ``,\n  recipes,\n  ``,\n  `✨ *Both recipes approved by the spirits! Let me know how it turns out~*`\n].join('\\n');\n\nreturn [{ json: { message, token, applicationId } }];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          576,
          64
        ],
        "id": "a81f3bc3-1abd-401a-9006-14aadb84d8ee",
