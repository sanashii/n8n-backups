    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data || $input.first().json.body || \"\";\n\n// 1. Check if the \"No Gale Warning\" text exists\nconst noWarningFound = html.includes(\"no Gale Warning Issued\") || html.includes(\"No active gale warning\");\n\n// 2. Define your \"Critical Zones\" for the Leyte move\nconst myZones = [\"Leyte\", \"Biliran\", \"Naval\", \"Carigara\", \"Ormoc\"];\n\n// 3. Search for any mention of your zones in the HTML\n// This acts as a fallback even if the parsing isn't perfect\nconst mentionedZones = myZones.filter(zone => \n  new RegExp(`\\\\b${zone}\\\\b`, 'i').test(html)\n);\n\n// 4. Determine the Boat Status\nlet boatStatus = \"PROBABLY OK\";\nlet alertLevel = \"Green\";\n\nif (!noWarningFound) {\n  boatStatus = \"WARNING ACTIVE - CHECK COAST GUARD\";\n  alertLevel = \"Yellow\";\n}\n\nif (mentionedZones.length > 0 && !noWarningFound) {\n  boatStatus = \"DANGER: LEYTE/BILIRAN AFFECTED - BOATS LIKELY STOPPED\";\n  alertLevel = \"Red\";\n}\n\nreturn [\n  {\n    json: {\n      timestamp: new Date().toLocaleString(\"en-PH\", { timeZone: \"Asia/Manila\" }),\n      is_gale_active: !noWarningFound,\n      affected_my_areas: mentionedZones,\n      status: boatStatus,\n      alert_color: alertLevel,\n      raw_text_summary: html.replace(/<[^>]*>?/gm, ' ').substring(0, 500) // First 500 chars of text\n    }\n  }\n];"
      },
