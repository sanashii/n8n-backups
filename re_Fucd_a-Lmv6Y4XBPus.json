      {
        "parameters": {
          "jsCode": "// Get the HTML content\nconst html = $input.first().json.data || $input.first().json.body || \"\";\n\n// We'll look for these specific keys in the HTML\nconst targets = [\n  { label: \"Cebu\", search: \"Cebu City\" },\n  { label: \"Naval\", search: \"Naval\" },\n  { label: \"Biliran\", search: \"Biliran\" }\n];\n\nconst results = targets.map(target => {\n  // This Regex looks for the city name and grabs everything until the next HTML tag or coordinate\n  // It handles the \"partly cloudy\" text seen in your screenshot.\n  const regex = new RegExp(`${target.search}[\\\\s\\\\S]{1,50}?<div[^>]*>([\\\\s\\\\S]{5,150}?)<\\\\/div>`, 'i');\n  const match = html.match(regex);\n  \n  let forecastText = match ? match[1].replace(/<[^>]*>?/gm, '').trim() : \"Clear Skies\"; \n  \n  // If the scrape fails but we see \"Clear Skies\" icons in the HTML, \n  // we default to a safe \"Fair Weather\" unless a warning is found below.\n  return {\n    location: target.label,\n    forecast: forecastText\n  };\n});\n\n// Capture the CRITICAL alerts for boat travel\nconst thunderstormAlert = html.match(/Thunderstorm (Watch|Information) #VISPRSD[\\s\\S]{1,500}?(within 12 hours|persist)/i);\nconst galeWarning = html.match(/Gale Warning[\\s\\S]{1,500}?(Rough to Very Rough)/i);\n\nreturn [\n  {\n    json: {\n      timestamp: new Date().toLocaleString(\"en-PH\", { timeZone: \"Asia/Manila\" }),\n      locations: results,\n      alerts: {\n        thunderstorm: thunderstormAlert ? thunderstormAlert[0].replace(/<[^>]*>?/gm, ' ').trim() : \"None\",\n        gale_warning: galeWarning ? \"ACTIVE GALE WARNING - Boats likely stopped\" : \"None\"\n      }\n    }\n  }\n];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1056,
          144
        ],
        "id": "de1d89df-a021-4794-993a-49b44d232e33",
        "name": "Code in JavaScript"
      },
      {
        "parameters": {
          "url": "https://www.pagasa.dost.gov.ph/marine/gale-warning",
          "options": {}
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.4,
        "position": [
          1264,
          144
        ],
        "id": "c67ce15d-a729-480d-b252-e4c85d597e77",
        "name": "HTTP Request"
      },
      {
        "parameters": {
          "jsCode": "const html = $input.first().json.data || $input.first().json.body || \"\";\n\n// 1. Check if the \"No Gale Warning\" text exists\nconst noWarningFound = html.includes(\"no Gale Warning Issued\") || html.includes(\"No active gale warning\");\n\n// 2. Define your \"Critical Zones\" for the Leyte move\nconst myZones = [\"Leyte\", \"Biliran\", \"Naval\", \"Carigara\", \"Ormoc\"];\n\n// 3. Search for any mention of your zones in the HTML\n// This acts as a fallback even if the parsing isn't perfect\nconst mentionedZones = myZones.filter(zone => \n  new RegExp(`\\\\b${zone}\\\\b`, 'i').test(html)\n);\n\n// 4. Determine the Boat Status\nlet boatStatus = \"PROBABLY OK\";\nlet alertLevel = \"Green\";\n\nif (!noWarningFound) {\n  boatStatus = \"WARNING ACTIVE - CHECK COAST GUARD\";\n  alertLevel = \"Yellow\";\n}\n\nif (mentionedZones.length > 0 && !noWarningFound) {\n  boatStatus = \"DANGER: LEYTE/BILIRAN AFFECTED - BOATS LIKELY STOPPED\";\n  alertLevel = \"Red\";\n}\n\nreturn [\n  {\n    json: {\n      timestamp: new Date().toLocaleString(\"en-PH\", { timeZone: \"Asia/Manila\" }),\n      is_gale_active: !noWarningFound,\n      affected_my_areas: mentionedZones,\n      status: boatStatus,\n      alert_color: alertLevel,\n      raw_text_summary: html.replace(/<[^>]*>?/gm, ' ').substring(0, 500) // First 500 chars of text\n    }\n  }\n];"
        },
        "type": "n8n-nodes-base.code",
