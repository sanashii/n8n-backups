    {
      "parameters": {
        "jsCode": "// Get the HTML content\nconst html = $input.first().json.data || $input.first().json.body || \"\";\n\n// We'll look for these specific keys in the HTML\nconst targets = [\n  { label: \"Cebu\", search: \"Cebu City\" },\n  { label: \"Naval\", search: \"Naval\" },\n  { label: \"Biliran\", search: \"Biliran\" }\n];\n\nconst results = targets.map(target => {\n  const regex = new RegExp(`${target.search}[\\\\s\\\\S]{1,50}?<div[^>]*>([\\\\s\\\\S]{5,150}?)<\\\\/div>`, 'i');\n  const match = html.match(regex);\n  let forecastText = match ? match[1].replace(/<[^>]*>?/gm, '').trim() : \"Clear Skies\";\n  return { location: target.label, forecast: forecastText };\n});\n\nconst thunderstormAlert = html.match(/Thunderstorm (Watch|Information) #VISPRSD[\\s\\S]{1,500}?(within 12 hours|persist)/i);\nconst galeWarning = html.match(/Gale Warning[\\s\\S]{1,500}?(Rough to Very Rough)/i);\n\nreturn [\n  {\n    json: {\n      timestamp: new Date().toLocaleString(\"en-PH\", { timeZone: \"Asia/Manila\" }),\n      locations: results,\n      alerts: {\n        thunderstorm: thunderstormAlert ? thunderstormAlert[0].replace(/<[^>]*>?/gm, ' ').trim() : \"None\",\n        gale_warning: galeWarning ? \"ACTIVE GALE WARNING - Boats likely stopped\" : \"None\"\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        592,
        -128
      ],
      "id": "6fcf4d55-ea62-4afe-8bbb-1a3c9f8077cc",
