        "name": "Get Visayas PAGASA Forecast"
      },
      {
        "parameters": {
          "jsCode": "// Get the HTML content\nconst html = $input.first().json.data || $input.first().json.body || \"\";\n\n// We'll look for these specific keys in the HTML\nconst targets = [\n  { label: \"Cebu\", search: \"Cebu City\" },\n  { label: \"Naval\", search: \"Naval\" },\n  { label: \"Biliran\", search: \"Biliran\" }\n];\n\nconst results = targets.map(target => {\n  const regex = new RegExp(`${target.search}[\\\\s\\\\S]{1,50}?<div[^>]*>([\\\\s\\\\S]{5,150}?)<\\\\/div>`, 'i');\n  const match = html.match(regex);\n  let forecastText = match ? match[1].replace(/<[^>]*>?/gm, '').trim() : \"Clear Skies\";\n  return { location: target.label, forecast: forecastText };\n});\n\nconst thunderstormAlert = html.match(/Thunderstorm (Watch|Information) #VISPRSD[\\s\\S]{1,500}?(within 12 hours|persist)/i);\nconst galeWarning = html.match(/Gale Warning[\\s\\S]{1,500}?(Rough to Very Rough)/i);\n\nreturn [\n  {\n    json: {\n      timestamp: new Date().toLocaleString(\"en-PH\", { timeZone: \"Asia/Manila\" }),\n      locations: results,\n      alerts: {\n        thunderstorm: thunderstormAlert ? thunderstormAlert[0].replace(/<[^>]*>?/gm, ' ').trim() : \"None\",\n        gale_warning: galeWarning ? \"ACTIVE GALE WARNING - Boats likely stopped\" : \"None\"\n      }\n    }\n  }\n];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          592,
          -128
        ],
        "id": "6fcf4d55-ea62-4afe-8bbb-1a3c9f8077cc",
        "name": "Code in JavaScript"
      },
      {
        "parameters": {
          "url": "https://www.pagasa.dost.gov.ph/marine/gale-warning",
          "options": {}
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.4,
        "position": [
          816,
          -128
        ],
        "id": "082775d5-2cc5-4883-8073-df69eb7568c9",
        "name": "HTTP Request"
      },
      {
        "parameters": {
          "jsCode": "const html = $input.first().json.data || $input.first().json.body || \"\";\n\nconst noWarningFound = html.includes(\"no Gale Warning Issued\") || html.includes(\"No active gale warning\");\nconst myZones = [\"Leyte\", \"Biliran\", \"Naval\", \"Carigara\", \"Ormoc\"];\nconst mentionedZones = myZones.filter(zone =>\n  new RegExp(`\\\\b${zone}\\\\b`, 'i').test(html)\n);\n\nlet boatStatus = \"PROBABLY OK\";\nlet alertLevel = \"Green\";\n\nif (!noWarningFound) {\n  boatStatus = \"WARNING ACTIVE - CHECK COAST GUARD\";\n  alertLevel = \"Yellow\";\n}\n\nif (mentionedZones.length > 0 && !noWarningFound) {\n  boatStatus = \"DANGER: LEYTE/BILIRAN AFFECTED - BOATS LIKELY STOPPED\";\n  alertLevel = \"Red\";\n}\n\nreturn [\n  {\n    json: {\n      timestamp: new Date().toLocaleString(\"en-PH\", { timeZone: \"Asia/Manila\" }),\n      is_gale_active: !noWarningFound,\n      affected_my_areas: mentionedZones,\n      status: boatStatus,\n      alert_color: alertLevel,\n      raw_text_summary: html.replace(/<[^>]*>?/gm, ' ').substring(0, 500)\n    }\n  }\n];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1072,
          -128
        ],
        "id": "5a8adb4e-d141-47e6-a972-cd19528b51a6",
        "name": "Code in JavaScript1"
      },
      {
        "parameters": {
          "text": "=OPEN-METEO DATA:\nWind Gusts: {{ $node[\"Get OpenMeteo details\"].json.current.wind_gusts_10m }} km/h\nPrecipitation: {{ $node[\"Get OpenMeteo details\"].json.current.precipitation }} mm\n\nPAGASA REGIONAL FORECAST:\n{{ $node[\"Code in JavaScript\"].json.locations[0].location }}: {{ $node[\"Code in JavaScript\"].json.locations[0].forecast }}\nThunderstorm Alert: {{ $node[\"Code in JavaScript\"].json.alerts.thunderstorm }}\n\nGALE WARNING STATUS:\n{{ $node[\"Code in JavaScript1\"].json.status }}\nAffected Areas: {{ $node[\"Code in JavaScript1\"].json.affected_my_areas }}",
          "attributes": {
            "attributes": [
              {
                "name": "overall_risk",
                "description": "Rate the travel risk as \"LOW\", \"MODERATE\", or \"HIGH\" based on wind > 40km/h or Gale Warnings."
              },
              {
                "name": "boat_cancellation_likelihood",
                "description": "Percentage chance (0-100%) that boats between Cebu and Naval will be cancelled."
              },
              {
                "name": "message_summary",
                "description": "Write a short 2-3 line Discord update in the voice of Okarun (Ken Takakura) from Dandadan — a nerdy, dramatic, slightly awkward teenage boy who is obsessed with the occult and aliens. He speaks with intense passion and over-the-top energy. Use phrases like 'My readings indicate...', 'This is no ordinary storm!', 'I have analyzed the data!', or 'According to my calculations...'. Reference aliens or supernatural phenomena humorously if conditions are bad. Use emojis like ⚠️ 👽 🌊 🚢 🔭. Mention Biliran and the Cebu-Naval route specifically."
              },
              {
                "name": "is_emergency",
                "description": "Set to True only if a Gale Warning is active for Leyte/Biliran or Wind Gusts > 60km/h."
              }
            ]
          },
          "options": {}
        },
